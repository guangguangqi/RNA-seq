# Step 2: Architecture Definitions
# ==========================================
class MaskedAutoencoder(nn.Module):
    def __init__(self, dims, latent_dim=128):
        super().__init__()
        self.encoders = nn.ModuleDict({
            k: nn.Sequential(nn.Linear(v, 512), nn.BatchNorm1d(512), nn.ReLU(), nn.Linear(512, latent_dim)) 
            for k, v in dims.items()
        })
        self.decoders = nn.ModuleDict({
            k: nn.Sequential(nn.Linear(latent_dim, 512), nn.ReLU(), nn.Linear(512, v)) 
            for k, v in dims.items()
        })

    def forward(self, x_dict, m_dict):
        embs, recons = {}, {}
        for k in x_dict:
            z = self.encoders[k](x_dict[k] * m_dict[k]) 
            embs[k] = z * m_dict[k]
            recons[k] = self.decoders[k](embs[k])
        return embs, recons

class ExpressiveFusion(nn.Module):
    def __init__(self, latent_dim=128, num_heads=4):
        super().__init__()
        self.mha = nn.MultiheadAttention(embed_dim=latent_dim, num_heads=num_heads, batch_first=True)
        self.ffn = nn.Sequential(
            nn.Linear(latent_dim, latent_dim * 2), nn.ReLU(), nn.Linear(latent_dim * 2, latent_dim)
        )
        self.norm1 = nn.LayerNorm(latent_dim)
        self.norm2 = nn.LayerNorm(latent_dim)
        # 🔥 Removed Sigmoid: Softmax needs raw scores (logits) to work best
        self.gate = nn.Linear(latent_dim, 1) 
        #####


    def forward(self, x_stack, mask_stack):
        key_padding_mask = (mask_stack.squeeze(-1) == 0)
        attn_out, _ = self.mha(x_stack, x_stack, x_stack, key_padding_mask=key_padding_mask)
        x = self.norm1(x_stack + attn_out)
        x = self.norm2(x + self.ffn(x))

        # ✅ Fix 5: Softmax competition
        # Shape change: [batch, 5, 1] -> [batch, 5]
        gate_scores = self.gate(x).squeeze(-1)
        
        # Mask missing modalities so they receive 0 weight
        gate_scores = gate_scores.masked_fill(mask_stack.squeeze(-1) == 0, -1e9)
        
        # Convert to probability distribution across the 5 modalities
        gates = torch.softmax(gate_scores, dim=1).unsqueeze(-1)

        return (x * gates).sum(dim=1)


def edge_dropout(edge_index, edge_attr, p=0.1, training=True):
    if not training: return edge_index, edge_attr
    mask = torch.rand(edge_index.shape[1], device=edge_index.device) > p
    return edge_index[:, mask], edge_attr[mask]


class SurvivalGNN(nn.Module):
    def __init__(self, latent_dim=64, dropout_rate=0.4):
        super().__init__()
        self.fusion = ExpressiveFusion(latent_dim=128, num_heads=4)
        
        # Layer 1: Keep 128 dims (32 * 4 heads)
        self.conv1 = GATConv(128, 32, heads=4, edge_dim=5) 
        
        # ✅ Fix: Reduce Conv2 to 64 dims to prevent "aggressiveness"
        self.conv2 = GATConv(128, 64, heads=1, edge_dim=5) 
        
        self.head = nn.Sequential(
            # ✅ Fix: Match BatchNorm and Linear to 64
            nn.BatchNorm1d(64),
            nn.Linear(64, 1)
        )
        self.dropout_rate = dropout_rate

    def forward(self, data):
        mod_stack = torch.stack([data.rna, data.snp, data.cnv, data.pro, data.cli], dim=1)
        mask_stack = torch.stack([data.m_rna, data.m_snp, data.m_cnv, data.m_pro, data.m_cli], dim=1)
        
        x = self.fusion(mod_stack, mask_stack) # 128-dim
        
        ei, ea = edge_dropout(data.edge_index, data.edge_attr, p=0.1, training=self.training)
        
        x = F.elu(self.conv1(x, ei, ea))
        x = F.dropout(x, p=self.dropout_rate, training=self.training)
        
        # ⚠️ Residual removed here because 128 != 64
        x = self.conv2(x, ei, ea) 
        
        return self.head(x)






