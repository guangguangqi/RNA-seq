import os
from sklearn.metrics import pairwise_distances
from sklearn.metrics.pairwise import cosine_similarity
from sklearn.neighbors import NearestNeighbors

def normalize_sim(sim):
    return (sim - np.mean(sim)) / (np.std(sim) + 1e-8)

def build_biological_graph(rna_df, string_df, cnv_df, snp_df, pro_df, top_k=8):
    # --- 1. STRING Prior (Precompute/Load Logic) ---
    if os.path.exists("sim_bio_prior.npy"):
       sim_bio_prior = np.load("sim_bio_prior.npy")
    else:
    # Find genes present in both RNA columns AND STRING
      common = sorted(list(set(string_df['gene1']).intersection(rna_df.columns).intersection(string_df['gene2'])))
      gene_to_idx = {g: i for i, g in enumerate(common)}
    
    # 🔥 FIXED: Filter the dataframe ONCE so row, col, and score have the SAME length
      string_sub = string_df[
        string_df['gene1'].isin(common) & 
        string_df['gene2'].isin(common)
      ].copy()

    # Create Adjacency with consistent arrays
      A = csr_matrix(
        (string_sub['score'].values, 
         (string_sub['gene1'].map(gene_to_idx).values, 
          string_sub['gene2'].map(gene_to_idx).values)), 
        shape=(len(common), len(common))
      )
    
    # Biological Projection (Projecting gene-prior onto patients)
    # Ensure RNA is aligned to the same 'common' genes
      X = StandardScaler().fit_transform(rna_df[common])
      sim_bio_prior = (X @ A) @ X.T
    
    # Stability: Log + Normalize
      sim_bio_prior = np.log1p(np.abs(sim_bio_prior))
      sim_bio_prior = (sim_bio_prior - sim_bio_prior.mean()) / (sim_bio_prior.std() + 1e-8)
      np.save("sim_bio_prior.npy", sim_bio_prior) 

    # --- 2. Multi-Channel Similarities ---
    sim_rna = normalize_sim(cosine_similarity(StandardScaler().fit_transform(rna_df)))
    sim_cnv = normalize_sim(cosine_similarity(StandardScaler().fit_transform(cnv_df)))
    sim_pro = normalize_sim(cosine_similarity(StandardScaler().fit_transform(pro_df)))
    # Jaccard for SNPs (Centered)
    sim_snp = 1 - pairwise_distances(snp_df.values, metric='jaccard')
    sim_snp = sim_snp - np.mean(sim_snp)

    # --- 3. Symmetric Topology ---
    knn = NearestNeighbors(n_neighbors=top_k + 1, metric='cosine')
    knn.fit(StandardScaler().fit_transform(rna_df))
    _, indices = knn.kneighbors(StandardScaler().fit_transform(rna_df))
    
    edge_index, edge_attr = [], []
    for i in range(len(rna_df)):
        for neighbor_idx in indices[i, 1:]:
            attr = [sim_rna[i, neighbor_idx], sim_cnv[i, neighbor_idx], 
                    sim_snp[i, neighbor_idx], sim_pro[i, neighbor_idx], 
                    sim_bio_prior[i, neighbor_idx]]
            
            # Add Symmetric Edges (Undirected Graph)
            edge_index.extend([[i, neighbor_idx], [neighbor_idx, i]])
            edge_attr.extend([attr, attr])
            
    return torch.tensor(edge_index).t().contiguous(), torch.tensor(edge_attr, dtype=torch.float)

