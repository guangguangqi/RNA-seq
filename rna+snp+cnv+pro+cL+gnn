def cox_loss(pred, y, event):
     # Sort by time descending to establish the risk set
    _, idx = torch.sort(y, descending=True)
    p_ord, e_ord = pred[idx], event[idx]

    # ✅ Step 3: Numerically Stable Log-Sum-Exp Trick
    # Subtracting the max value prevents exponential overflow
    max_val = torch.max(p_ord)
    # log_risk = log(sum(exp(x - max))) + max
    log_risk = torch.log(torch.cumsum(torch.exp(p_ord - max_val), dim=0) + 1e-8) + max_val
    
    # Negative Partial Log-Likelihood
    loss = -torch.sum(e_ord * (p_ord - log_risk)) / (torch.sum(e_ord) + 1e-8)
    return loss


input_dims = {'rna': rna.shape[1], 'snp': snp.shape[1], 'cnv': cnv.shape[1], 'pro': pro.shape[1], 'cli': final_feats.shape[1]}
ae_model = MaskedAutoencoder(input_dims).to(device)
gnn_model = SurvivalGNN().to(device)

ae_input = {k: torch.tensor(v.values, dtype=torch.float).to(device) for k, v in zip(input_dims.keys(), [rna, snp, cnv, pro, final_feats])}

edge_index, edge_attr = build_biological_graph(rna, string_df, cnv, snp, pro, top_k=5)

data = Data(m_rna=m_tensors['rna'], m_snp=m_tensors['snp'], m_cnv=m_tensors['cnv'], m_pro=m_tensors['pro'], m_cli=m_tensors['cli'], 
            edge_index=edge_index.to(device), edge_attr=edge_attr.to(device),
            y=torch.tensor(final_labels['time'].fillna(0).values, dtype=torch.float).to(device), 
            event=torch.tensor(final_labels['event'].fillna(0).values, dtype=torch.float).to(device))



valid_idx = np.where(~final_labels['time'].isna())[0]
train_idx, val_idx = train_test_split(valid_idx, test_size=0.2, random_state=42)


# ==========================================
# Step 5: End-to-End Training Loop
# ==========================================

best_c, counter, patience = 0, 0, 50

optimizer = torch.optim.Adam(
    list(ae_model.parameters()) + list(gnn_model.parameters()), 
    lr=1e-4, 
    weight_decay=1e-5
)
scheduler = StepLR(optimizer, step_size=50, gamma=0.5)


for epoch in range(801):
    # ... (forward pass code) ...

    ae_model.train()
    gnn_model.train()
    optimizer.zero_grad()

    # Forward
    embs, recons = ae_model(ae_input, m_tensors)
    data.rna, data.snp, data.cnv, data.pro, data.cli = (
        embs['rna'], embs['snp'], embs['cnv'], embs['pro'], embs['cli']
    )
    predictions = gnn_model(data).squeeze()
    predictions = torch.clamp(predictions, -10, 10) 
    # Loss
    ae_loss = sum(F.mse_loss(recons[k] * m_tensors[k], ae_input[k] * m_tensors[k]) for k in ae_input)
    surv_loss = cox_loss(predictions[train_idx], data.y[train_idx], data.event[train_idx])

    # 🔥 Smooth curriculum
    warmup = 100
    alpha = min(0.2, (epoch - warmup) / 200.0)

    surv_loss_scaled = surv_loss / (torch.std(predictions[train_idx]) + 1e-8)

    total_loss = ae_loss + alpha * surv_loss_scaled  


    # Backprop
    total_loss.backward()
    torch.nn.utils.clip_grad_norm_(ae_model.parameters(), 1.0)
    torch.nn.utils.clip_grad_norm_(gnn_model.parameters(), 1.0)
    optimizer.step()
    scheduler.step()

    if epoch == 100:
      print(">>> Transitioning to Fine-Tuning: Reducing AE learning rate.")
    # Give the GNN the full 1e-4, but drop the AE to a tiny 1e-6
      optimizer = torch.optim.Adam([
        {'params': gnn_model.parameters(), 'lr': 1e-4},
        {'params': ae_model.parameters(), 'lr': 1e-6, 'weight_decay': 1e-2} # "Lasso-style" decay
      ])

    # Eval
    if epoch % 20 == 0:
        ae_model.eval()
        gnn_model.eval() # Ensure dropout is off

        with torch.no_grad():
            v_embs, _ = ae_model(ae_input, m_tensors)
            data.rna, data.snp, data.cnv, data.pro, data.cli = (
                v_embs['rna'], v_embs['snp'], v_embs['cnv'], v_embs['pro'], v_embs['cli']
            )
            
            # GNN is in eval mode, so Dropout is inactive
            preds_val = gnn_model(data).squeeze()[val_idx].cpu().numpy()
            c_index = concordance_index(data.y[val_idx].cpu(), -preds_val, data.event[val_idx].cpu())

            print(f"Epoch {epoch:03d} | Total Loss: {total_loss.item():.4f} | Val C: {c_index:.4f}")

            # Only start checking patience after the curriculum has matured (e.g., epoch 150)
            if c_index > best_c:
                best_c = c_index
                counter = 0
                torch.save({'ae': ae_model.state_dict(), 'gnn': gnn_model.state_dict()}, "best_model.pt")
            elif epoch > 150: # Only count towards patience after survival signal is dominant
                counter += 1
                if counter >= patience:
                    print(f"Early stopping at epoch {epoch}. Best Val C: {best_c:.4f}")
                    break
     
